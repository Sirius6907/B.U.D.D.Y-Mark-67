# =================================================================
# B.U.D.D.Y-Mark-67 // PROTOCOL SIRIUS - Configuration Template
# =================================================================

# --- Core Intelligence (Google Gemini) ---
# Get your API key at: https://aistudio.google.com/
BUDDY_GEMINI_API_KEY=your_gemini_api_key_here

# --- Neural Voice Engine (Sarvam AI) ---
# Comma-separated pool of API keys to handle rate limits
SARVAM_API_KEYS=key_one,key_two
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=Ritu
SARVAM_TTS_LANGUAGE=en-IN

# --- Remote Control (Telegram) ---
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your numerical Telegram ID (use @userinfobot to find it)
TELEGRAM_USER_ID=your_chat_id_here
# Your Telegram username (optional secondary auth)
TELEGRAM_USERNAME=your_username

# --- System Environment ---
# Options: windows, linux (windows is primary target)
BUDDY_OS=windows
# Options: DEBUG, INFO, WARNING, ERROR
BUDDY_LOG_LEVEL=INFO
# Options: development, production
BUDDY_ENV=production

# --- Advanced Tuning ---
# Primary voice provider: sarvam or gemini
VOICE_PROVIDER_PRIMARY=sarvam
VOICE_PROVIDER_FALLBACK=gemini
# STT language hint (default: unknown for auto-detect)
SARVAM_STT_LANGUAGE_HINT=unknown
